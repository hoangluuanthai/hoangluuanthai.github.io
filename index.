<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thông tin liên hệ</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f4f9; /* Màu nền xám nhạt chuyên nghiệp */
            display: flex;
            flex-direction: column;
            align-items: center;
            padding-top: 60px;
            margin: 0;
        }
        .profile-pic {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            object-fit: cover;
            margin-bottom: 20px;
            border: 3px solid #24292e;
        }
        h1 { color: #24292e; margin: 0; font-size: 24px; }
        p { color: #586069; margin-bottom: 30px; text-align: center; max-width: 320px; line-height: 1.5; }
        .link-btn {
            display: block;
            width: 260px;
            padding: 14px;
            margin-bottom: 16px;
            text-align: center;
            background-color: #ffffff;
            color: #24292e;
            text-decoration: none;
            border: 2px solid #24292e;
            border-radius: 8px;
            font-weight: bold;
            transition: all 0.2s ease;
            box-shadow: 2px 2px 0px #24292e; /* Hiệu ứng đổ bóng phong cách tech */
        }
        .link-btn:hover {
            background-color: #24292e;
            color: #ffffff;
            box-shadow: 4px 4px 0px #586069;
            transform: translateY(-2px);
        }
    </style>
</head>
<body>
    <!-- 1. Thay link ảnh avatar của bạn vào phần src="..." -->
    <img src="https://via.placeholder.com/150" alt="Avatar" class="profile-pic">

    <!-- 2. Sửa tên và phần giới thiệu -->
    <h1>Tên Của Bạn</h1>
    <p>Sinh viên Kỹ thuật | Đam mê Hệ thống nhúng & Tự động hóa</p>

    <!-- 3. Sửa các đường link -->
    <a href="https://github.com/Tên_Của_Bạn" class="link-btn" target="_blank">💻 GitHub Profile</a>
    <a href="https://linkedin.com/in/Tên_Của_Bạn" class="link-btn" target="_blank">🔗 LinkedIn Network</a>
    
    <!-- Link Email: Giữ nguyên chữ mailto: và thêm email của bạn vào sau -->
    <a href="mailto:email.cua.ban@gmail.com" class="link-btn">✉️ Gửi Email</a>
</body>
</html>
